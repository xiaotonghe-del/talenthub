{
    "name": "talenthub-backend",
    "version": "2.0.0",
    "description": "TalentHub backend with criteria filtering and LLM-driven profile sync",
    "main": "server.js",
    "type": "module",
  "scripts": {
    "start": "npx prisma generate && npx prisma db push --accept-data-loss && node server.js",
    "dev": "node --watch server.js",
    "db:push": "prisma db push",
    "db:seed": "node seed.js"
},
    "dependencies": {
      "@prisma/client": "^5.22.0",
      "cors": "^2.8.5",
      "dotenv": "^16.4.5",
      "express": "^4.21.1",
      "node-cron": "^3.0.3",
      "openai": "^4.73.0"
    },
    "devDependencies": {
      "prisma": "^5.22.0"
    },
    "engines": {
      "node": ">=18.0.0"
    }
  }