# --- Database (Railway 会自动设置，本地暂时不用填) ---
DATABASE_URL=postgresql://user:pass@host:5432/db

# --- LLM: OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-你的key填这里
LLM_MODEL=openai/gpt-4o-mini

# --- Optional: Tavily (先不用) ---
# TAVILY_API_KEY=tvly-xxxxx

# --- 给 Cron 设置的密码（随便填一串随机字符）---
CRON_SECRET=my-random-secret-12345

# --- Server 端口 ---
PORT=3000